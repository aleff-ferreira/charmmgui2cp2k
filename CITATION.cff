    family-names: Ferreira
    # TODO: add affiliation and ORCID
license: MIT
repository-code: "https://github.com/aleff-ferreira/charmmgui2cp2k"
keywords:
  - QM/MM
  - CP2K
  - CHARMM-GUI
  - AMBER
  - molecular dynamics
  - computational chemistry
  - bioinformatics
version: "0.1.0"
date-released: "2026-06-18"
